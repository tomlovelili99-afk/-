{
  "name": "xiong-pengcheng-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:host": "vite --host 0.0.0.0",
    "build": "pnpm run optimize:images && vite build && node scripts/prune-dist-assets.mjs",
    "check:assets": "node scripts/check-public-assets.mjs",
    "optimize:images": "node scripts/optimize-gallery-assets.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "preview:host": "vite preview --host 0.0.0.0",
    "render:pdf-pages": "python3 scripts/render-pdf-pages.py"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@vitejs/plugin-react": "6.0.3",
    "gsap": "3.15.0",
    "ogl": "^1.0.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  }
}
